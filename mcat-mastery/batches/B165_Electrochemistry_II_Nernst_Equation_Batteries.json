    {
      "id": "cp_nernst2_010",
      "passage": null,
      "stem": "Why is voltage not determined only by electrode identity?",
      "choices": [
        {
          "label": "A",
          "text": "Electrode identity is irrelevant to standard potential"
        },
        {
          "label": "B",
          "text": "Ion concentrations and reaction quotient also affect cell potential"
        },
        {
          "label": "C",
          "text": "Voltage is independent of redox chemistry"
        },
        {
          "label": "D",
          "text": "Only wire length determines voltage"
        }
      ],
      "correct": "B",
      "explanations": {
        "A": "Electrode identity strongly affects standard potential, so saying it is irrelevant overcorrects the point.",
        "B": "Correct. Electrode materials set standard reduction potentials, but actual voltage also depends on concentrations through the Nernst equation. The table shows the same metals giving different voltages when ion concentrations change.",
        "C": "Voltage is fundamentally tied to redox chemistry in the cell. Concentration effects refine, not replace, that chemistry.",
        "D": "Wire length may affect resistance slightly, but it does not set the thermodynamic cell potential."
      },
