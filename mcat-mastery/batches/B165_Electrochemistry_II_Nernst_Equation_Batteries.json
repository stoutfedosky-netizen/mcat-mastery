    {
      "id": "cp_nernst2_003",
      "passage": null,
      "stem": "Why does high [Zn\u00b2\u207a] lower the cell voltage?",
      "choices": [
        {
          "label": "A",
          "text": "It increases product concentration and makes the spontaneous reaction less favorable"
        },
        {
          "label": "B",
          "text": "It removes all zinc metal instantly"
        },
        {
          "label": "C",
          "text": "It changes copper into a gas"
        },
        {
          "label": "D",
          "text": "It stops the salt bridge from carrying ions"
        }
      ],
      "correct": "A",
      "explanations": {
        "A": "Correct. Zn\u00b2\u207a is a product of the overall reaction. Increasing product concentration raises Q and reduces the driving force according to the Nernst relationship.",
        "B": "Zinc metal is still present as an electrode; higher Zn\u00b2\u207a shifts reaction tendency but does not instantly consume all solid zinc.",
        "C": "Copper does not become a gas in this aqueous redox cell. The voltage change is concentration-dependent, not a phase change.",
        "D": "The salt bridge can still maintain electroneutrality. The voltage shift comes from reaction quotient changes."
      },
      "topic": "Electrochemistry II: Nernst Equation & Batteries",
      "difficulty": "Medium",
      "passageRef": "cp_nernst2_001",
      "usePrevPassage": true
    },
    {
      "id": "cp_nernst2_004",
      "passage": null,
      "stem": "Why does high [Cu\u00b2\u207a] increase voltage?",
      "choices": [
        {
          "label": "A",
          "text": "It reverses the identity of anode and cathode necessarily"
        },
        {
          "label": "B",
          "text": "It makes Zn\u00b2\u207a disappear from solution"
        },
        {
          "label": "C",
          "text": "It increases reactant concentration for the reduction half-reaction"
        },
        {
          "label": "D",
          "text": "It blocks electron flow in the wire"
        }
      ],
      "correct": "C",
      "explanations": {
        "A": "The electrodes need not switch roles merely because concentration changes within the described range. The reaction remains zinc oxidation coupled to copper reduction.",
        "B": "Changing Cu\u00b2\u207a does not remove Zn\u00b2\u207a. The effect is on the reaction quotient, not selective disappearance of product.",
        "C": "Correct. Cu\u00b2\u207a is a reactant in the spontaneous cell reaction. Increasing its concentration lowers Q and makes reduction more favorable, increasing cell voltage.",
        "D": "Blocking electron flow would reduce current, not explain a higher open-circuit voltage."
      },
      "topic": "Electrochemistry II: Nernst Equation & Batteries",
      "difficulty": "Hard",
      "passageRef": "cp_nernst2_001",
