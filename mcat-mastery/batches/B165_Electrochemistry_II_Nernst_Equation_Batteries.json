      "passage": null,
      "stem": "What is the role of the salt bridge?",
      "choices": [
        {
          "label": "A",
          "text": "It carries electrons faster than the wire"
        },
        {
          "label": "B",
          "text": "It maintains charge balance by allowing ion migration"
        },
        {
          "label": "C",
          "text": "It supplies all chemical energy"
        },
        {
          "label": "D",
          "text": "It plates copper onto zinc directly"
        }
