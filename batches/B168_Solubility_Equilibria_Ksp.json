      "passage": null,
      "stem": "Which statement best connects precipitation to Qsp?",
      "choices": [
        {
          "label": "A",
          "text": "Precipitation requires no ions in solution"
        },
        {
          "label": "B",
          "text": "Precipitation is favored when Qsp is zero"
        },
        {
          "label": "C",
          "text": "Precipitation is favored when Qsp exceeds Ksp"
        },
        {
          "label": "D",
          "text": "Precipitation ignores stoichiometry"
        }
      ],
      "correct": "C",
      "explanations": {
        "A": "Precipitation requires ions to combine into a solid; no ions means no precipitate.",
        "B": "If Qsp is zero, at least one ion is absent, so precipitation cannot occur for that salt.",
        "C": "Correct. When Qsp > Ksp, ion concentrations exceed what can remain dissolved at equilibrium, so solid forms until Qsp falls to Ksp.",
