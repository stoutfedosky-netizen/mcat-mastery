    {
      "id": "bb_renal2_004",
      "passage": null,
      "stem": "Patient C's high pH and high bicarbonate suggest:",
      "choices": [
        {
          "label": "A",
          "text": "lactic acidosis from shock"
        },
        {
          "label": "B",
          "text": "metabolic acidosis"
        },
        {
          "label": "C",
          "text": "uncompensated respiratory acidosis"
        },
        {
          "label": "D",
          "text": "metabolic alkalosis with respiratory compensation"
        }
      ],
      "correct": "D",
      "explanations": {
        "A": "Lactic acidosis would produce low pH and low bicarbonate, not the pattern shown.",
        "B": "Metabolic acidosis would lower bicarbonate and pH, not raise both.",
        "C": "Respiratory acidosis begins with high PCO\u2082 and low pH. Patient C is alkalemic.",
        "D": "Correct. High pH with elevated bicarbonate indicates metabolic alkalosis. The elevated PCO\u2082 is consistent with hypoventilatory compensation retaining CO\u2082 to lower pH toward normal."
      },
      "topic": "Renal Physiology II: Acid-Base & Electrolytes",
      "difficulty": "Hard",
