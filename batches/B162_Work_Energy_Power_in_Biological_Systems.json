    {
      "id": "cp_energy2_003",
      "passage": null,
      "stem": "Why is chemical energy expenditure greater than calculated mechanical work?",
      "choices": [
        {
          "label": "A",
          "text": "Gravity supplies all ATP during stair climbing."
        },
        {
          "label": "B",
          "text": "Mechanical work can never be positive in humans."
        },
        {
          "label": "C",
          "text": "Muscle contraction is not perfectly efficient, so some chemical energy becomes heat."
        },
        {
          "label": "D",
          "text": "Power is independent of time."
        }
      ],
      "correct": "C",
      "explanations": {
        "A": "Gravity opposes upward climbing and does not supply ATP. ATP hydrolysis powers cross-bridge cycling and ion pumping during muscle activity.",
        "B": "Humans can do positive external work, such as raising the center of mass during stair climbing. The issue is efficiency, not impossibility of work.",
        "C": "Correct. Skeletal muscle converts ATP chemical energy into mechanical work with limited efficiency. Some energy is dissipated as heat and internal work, so metabolic cost exceeds external gravitational work.",
        "D": "Power is explicitly work per time. The chemical-mechanical gap comes from efficiency losses, not from power being time independent."
      },
      "topic": "Muscle Efficiency",
      "difficulty": "Medium",
      "passageRef": "cp_energy2_001",
      "usePrevPassage": true
    },
    {
